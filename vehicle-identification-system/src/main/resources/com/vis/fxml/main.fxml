<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:id="mainPane"
            fx:controller="com.vis.controller.MainApp"
            styleClass="main-root">

    <!-- Top Menu Bar -->
    <top>
        <VBox>
            <MenuBar fx:id="menuBar" styleClass="menu-bar-modern">
                <Menu text="File">
                    <MenuItem text="Exit" onAction="#handleExit"/>
                </Menu>
                <Menu text="Modules">
                    <MenuItem text="Dashboard"  onAction="#showDashboard"/>
                    <MenuItem text="Client"   onAction="#showClient"/>
                    <MenuItem text="Workshop"   onAction="#showWorkshop"/>
                    <Menu text="Workshop Tools">
                        <MenuItem text="Service Record"   onAction="#showGarageInfo"/>
                        <MenuItem text="Workshop Search"  onAction="#showWorkshopSearch"/>
                        <MenuItem text="Service Registry" onAction="#showServiceRegistry"/>
                    </Menu>
                    <MenuItem text="Police"     onAction="#showPolice"/>
                    <Menu text="Police Tools">
                        <MenuItem text="Car Search"  onAction="#showPoliceSearch"/>
                        <MenuItem text="File Report"     onAction="#showPoliceInfo"/>
                        <MenuItem text="Issue Ticket"    onAction="#showPoliceTicket"/>
                    </Menu>
                    <MenuItem text="Insurance"  onAction="#showInsurance"/>
                    <Menu text="Insurance Tools">
                        <MenuItem text="Insurance Policy"  onAction="#showInsuranceForm"/>
                        <MenuItem text="Policies Registry" onAction="#showInsuranceRegistry"/>
                    </Menu>
                    <MenuItem text="Admin"      onAction="#showAdmin"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="My Profile" onAction="#showProfile"/>
                </Menu>
                <Menu text="Account">
                    <MenuItem text="Logout" onAction="#handleLogout"/>
                </Menu>
                <Menu text="Help">
                    <MenuItem text="About VIS"/>
                </Menu>
            </MenuBar>

            <!-- Top Bar -->
            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="topbar">
                <padding><Insets left="20" right="20" top="10" bottom="10"/></padding>
                <Label text="VIS" styleClass="topbar-logo"/>
                <Label text="Car Identification System" styleClass="topbar-title"/>
                <HBox HBox.hgrow="ALWAYS"/>
                <VBox alignment="CENTER_RIGHT" spacing="2">
                    <Label fx:id="PersonLabel" styleClass="topbar-Person"/>
                    <Label fx:id="roleLabel" styleClass="topbar-role"/>
                </VBox>
                <Button text="Logout" onAction="#handleLogout" styleClass="btn-logout"/>
            </HBox>
        </VBox>
    </top>

    <!-- Sidebar -->
    <left>
        <VBox fx:id="sidebar" spacing="6" styleClass="sidebar" prefWidth="220">
            <padding><Insets top="20" left="12" right="12" bottom="20"/></padding>
            <Label text="NAVIGATION" styleClass="sidebar-section-label"/>
            <Button text="Dashboard"  maxWidth="Infinity" onAction="#showDashboard"  styleClass="sidebar-btn"/>
            <Button text="Client"   maxWidth="Infinity" onAction="#showClient"   styleClass="sidebar-btn"/>
            <Button text="Workshop"   maxWidth="Infinity" onAction="#showWorkshop"   styleClass="sidebar-btn"/>
            <VBox fx:id="workshopSubNav" spacing="2" style="-fx-padding: 0 0 0 20;">
                <Button text="Service Record"   maxWidth="Infinity" onAction="#showGarageInfo"   styleClass="sidebar-btn-sub"/>
                <Button text="Workshop Search"  maxWidth="Infinity" onAction="#showWorkshopSearch"  styleClass="sidebar-btn-sub"/>
                <Button text="Service Registry" maxWidth="Infinity" onAction="#showServiceRegistry" styleClass="sidebar-btn-sub"/>
            </VBox>
            <Button text="Police"     maxWidth="Infinity" onAction="#showPolice"     styleClass="sidebar-btn"/>
            <VBox fx:id="policeSubNav" spacing="2" style="-fx-padding: 0 0 0 20;">
                <Button text="Car Search"  maxWidth="Infinity" onAction="#showPoliceSearch"    styleClass="sidebar-btn-sub"/>
                <Button text="File Report"     maxWidth="Infinity" onAction="#showPoliceInfo"    styleClass="sidebar-btn-sub"/>
                <Button text="Issue Ticket"    maxWidth="Infinity" onAction="#showPoliceTicket" styleClass="sidebar-btn-sub"/>
            </VBox>
            <Button text="Insurance"  maxWidth="Infinity" onAction="#showInsurance"  styleClass="sidebar-btn"/>
            <VBox fx:id="insuranceSubNav" spacing="2" style="-fx-padding: 0 0 0 20;">
                <Button text="Insurance Policy"  maxWidth="Infinity" onAction="#showInsuranceForm"  styleClass="sidebar-btn-sub"/>
                <Button text="Policies Registry" maxWidth="Infinity" onAction="#showInsuranceRegistry" styleClass="sidebar-btn-sub"/>
            </VBox>
            <Button text="My Profile" maxWidth="Infinity" onAction="#showProfile"    styleClass="sidebar-btn" style="-fx-text-fill: #94a3b8;"/>
            <Separator styleClass="divider"/>
            <Label text="SYSTEM" styleClass="sidebar-section-label"/>
            <Button text="Admin Panel" maxWidth="Infinity" onAction="#showAdmin"     styleClass="sidebar-btn-admin"/>
        </VBox>
    </left>

    <!-- Content Area -->
    <center>
        <StackPane fx:id="mainContentStack">
            <StackPane fx:id="contentArea" styleClass="content-area"/>
            
            <!-- Global Alert Banner -->
            <VBox fx:id="AlertBanner" alignment="CENTER" spacing="10" visible="false" managed="false"
                  StackPane.alignment="TOP_CENTER" maxHeight="60" 
                  style="-fx-background-color: rgba(30, 41, 59, 0.95); -fx-background-radius: 0 0 12 12; -fx-border-color: #3b82f6; -fx-border-width: 0 0 2 0;">
                <HBox alignment="CENTER" spacing="15">
                    <padding><Insets left="20" right="20" top="10" bottom="10"/></padding>
                    <Label fx:id="AlertIcon" text="📢" style="-fx-font-size: 18px;"/>
                    <Label fx:id="AlertText" text="System Update: The server will be down for Maintenance at 18:00." 
                           style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" HBox.hgrow="ALWAYS" wrapText="true"/>
                    <Button text="✕" onAction="#hideAlert" 
                            style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-cursor: hand; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
