<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.vis.controller.Login"
           style="-fx-background-color: #0d6efd;">

    <VBox fx:id="loginCard" alignment="CENTER" maxWidth="850" maxHeight="550" 
          style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 40, 0, 0, 15);">
        
        <HBox VBox.vgrow="ALWAYS">
            <clip>
                <Rectangle width="850" height="550" arcWidth="40" arcHeight="40"/>
            </clip>
            
            <!-- LEFT SIDE -->
            <AnchorPane prefWidth="425" style="-fx-background-color: linear-gradient(to bottom right, #0055D4, #003399);">
                <!-- Background Bubbles -->
                <Circle radius="180" layoutX="40" layoutY="450" fill="linear-gradient(to top right, #0066FF, #0044B2)"/>
                <Circle radius="110" layoutX="280" layoutY="430" fill="linear-gradient(to bottom, #0077FF, #0044B2)"/>
                
                <VBox alignment="CENTER_LEFT" AnchorPane.leftAnchor="50" AnchorPane.rightAnchor="50" AnchorPane.topAnchor="160" spacing="15">
                    <Label text="WELCOME" style="-fx-font-size: 36px; -fx-font-weight: 900; -fx-text-fill: white; -fx-letter-spacing: 2px;"/>
                    <Label text="NATIONAL REGISTRY" style="-fx-font-size: 14px; -fx-font-weight: 700; -fx-text-fill: white; -fx-letter-spacing: 1.5px;"/>
                    <Label text="Securing roads through advanced digital surveillance and integrated registry management for national vehicle administration." 
                           wrapText="true" style="-fx-font-size: 11px; -fx-text-fill: #b3d4ff; -fx-line-spacing: 6;"/>
                </VBox>
            </AnchorPane>

            <!-- RIGHT SIDE -->
            <AnchorPane prefWidth="425" style="-fx-background-color: white;">
                <!-- Bottom right bubble -->
                <Circle radius="80" layoutX="425" layoutY="550" fill="linear-gradient(to top left, #0066FF, #0044B2)"/>
                
                <VBox alignment="CENTER" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="55" AnchorPane.rightAnchor="55" spacing="15">
                    <VBox spacing="6" alignment="CENTER_LEFT" maxWidth="Infinity">
                        <Label text="Sign in" style="-fx-font-size: 32px; -fx-font-weight: 800; -fx-text-fill: #1e293b;"/>
                        <Label text="Please enter your credentials to access the system portal" style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;"/>
                    </VBox>
                    
                    <VBox spacing="12">
                        <!-- User Name -->
                        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #f1f5f9; -fx-background-radius: 8; -fx-padding: 2 12;">
                            <Label text="👤" style="-fx-text-fill: #64748b; -fx-font-size: 16px;"/>
                            <TextField fx:id="personnameField" promptText="User Name" style="-fx-background-color: transparent; -fx-padding: 12 10; -fx-font-size: 13px; -fx-text-fill: #1e293b;" HBox.hgrow="ALWAYS"/>
                        </HBox>
                        
                        <!-- Password -->
                        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #f1f5f9; -fx-background-radius: 8; -fx-padding: 2 12;">
                            <Label text="🔒" style="-fx-text-fill: #64748b; -fx-font-size: 16px;"/>
                            <PasswordField fx:id="passwordField" promptText="Password" style="-fx-background-color: transparent; -fx-padding: 12 10; -fx-font-size: 13px; -fx-text-fill: #1e293b;" HBox.hgrow="ALWAYS"/>
                            <Label text="SHOW" style="-fx-text-fill: #1e3a8a; -fx-font-size: 10px; -fx-font-weight: 800; -fx-cursor: hand;"/>
                        </HBox>
                    </VBox>
                    
                    <HBox alignment="CENTER" maxWidth="Infinity">
                        <CheckBox text="Remember me" style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Forgot Password?" style="-fx-background-color: transparent; -fx-text-fill: #0055D4; -fx-font-size: 11px; -fx-padding: 0; -fx-cursor: hand; -fx-font-weight: 600;"/>
                    </HBox>

                    <Label fx:id="statusLabel" visible="false" wrapText="true" maxWidth="Infinity" style="-fx-text-fill: #dc2626; -fx-font-size: 11px; -fx-font-weight: 600; -fx-background-color: #fef2f2; -fx-padding: 5; -fx-background-radius: 5;"/>
                    
                    <VBox spacing="12" maxWidth="Infinity">
                        <Button fx:id="loginBtn" text="Sign in" onAction="#handleLogin" maxWidth="Infinity" style="-fx-background-color: #1e3a8a; -fx-text-fill: white; -fx-font-weight: 700; -fx-padding: 14; -fx-background-radius: 8; -fx-font-size: 14px; -fx-cursor: hand;"/>
                        
                        <HBox alignment="CENTER" spacing="12">
                            <Separator HBox.hgrow="ALWAYS" style="-fx-opacity: 0.5;"/>
                            <Label text="Or" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px; -fx-font-weight: 600;"/>
                            <Separator HBox.hgrow="ALWAYS" style="-fx-opacity: 0.5;"/>
                        </HBox>
                        
                        <Button text="Sign in with other" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-border-color: #1e293b; -fx-border-radius: 8; -fx-text-fill: #1e293b; -fx-font-weight: 600; -fx-padding: 13; -fx-font-size: 13px; -fx-cursor: hand;"/>
                    </VBox>
                    
                    <HBox alignment="CENTER" spacing="5" style="-fx-padding: 10 0 0 0;">
                        <Label text="Don't have an account?" style="-fx-text-fill: #64748b; -fx-font-size: 11px;"/>
                        <Button fx:id="registerBtn" text="Sign Up" onAction="#handleRegister" style="-fx-background-color: transparent; -fx-text-fill: #0055D4; -fx-padding: 0; -fx-font-size: 11px; -fx-font-weight: 800; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </AnchorPane>
        </HBox>
    </VBox>

    <!-- Overlay Loading -->
    <VBox fx:id="loadingOverlay" alignment="CENTER" spacing="15" visible="false" style="-fx-background-color: rgba(255,255,255,0.8);">
        <ProgressIndicator prefWidth="50" prefHeight="50"/>
        <Label text="Authenticating..." style="-fx-font-weight: bold; -fx-text-fill: #1e3a8a; -fx-font-size: 14px;"/>
    </VBox>
</StackPane>
